<Page x:Class="YP.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage"
      Background="AntiqueWhite">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Background="#f6f3f3" CornerRadius="12" Padding="30" Width="380">
            <StackPanel Width="300">
                <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="«Читай, Пиши и не спиши»" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Логин" FontSize="14"/>
                <TextBox x:Name="txtUser" Margin="0,5,0,10" Height="25"/>

                <TextBlock Text="Пароль" FontSize="14"/>
                <PasswordBox x:Name="txtPassword" Margin="0,5,0,20" Height="25"/>

                <Button Content="Войти" Height="30" Click="AutoButton_Click" Background="#8895af" Foreground="White" BorderThickness="0"/>
                <Button Content="Регистрация" Height="30" Click="RegisterButton_Click" Background="Transparent" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
