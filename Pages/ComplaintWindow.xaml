<Window x:Class="YP.Pages.ComplaintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YP.Pages"
        mc:Ignorable="d"
        Title="ComplaintWindow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="AntiqueWhite">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Подача жалобы" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtTargetInfo" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtTargetName" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <TextBlock Text="Причина жалобы:" Margin="0,0,0,5" FontSize="14"/>
            <ComboBox x:Name="CmbReasons" DisplayMemberPath="Name" FontSize="12"/>

            <Button x:Name="BtnSend" Content="Отправить жалобу" FontSize="14" Width="180" Height="30" Margin="0,20,0,0" Background="#FF5722" Foreground="White" FontWeight="Bold" Click="BtnSend_Click"/>
        </StackPanel>
    </Grid>
</Window>
