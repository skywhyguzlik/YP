<Page x:Class="YP.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorPage"
      Background="AntiqueWhite">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="{Binding Login}" FontSize="14" Foreground="Gray"/>
                <TextBlock Text="{Binding Roles.RoleName, StringFormat='Роль: {0}'}" FontSize="14"/>
            </StackPanel>
            <Button x:Name="BtnAddNewBook" Content="Добавить книгу" Background="#8895af" Foreground="White" BorderThickness="0" Width="150" Height="35" Click="BtnAddNewBook_Click"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Мои книги">
                <ListBox x:Name="ListBoxBooks">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" Padding="8" Margin="0,0,0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding CoverPath}" Grid.Column="0" Width="80" Height="110" Stretch="UniformToFill" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding Description}" Width="400" TextTrimming="CharacterEllipsis" FontSize="14" Foreground="Gray"/>
                                    </StackPanel>
                                    <Button x:Name="BtnEditBook" Grid.Column="2" Content="Редактировать" Background="Transparent" Foreground="#2196F3" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnEditBook_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <TabItem Header="Замороженные книги">
                <ListBox x:Name="ListBoxFrozenBooks">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" Padding="8" Margin="0,0,0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding CoverPath}" Grid.Column="0" Width="80" Height="110" Stretch="UniformToFill" Margin="0,0,10,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,10,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="Заморожена" Foreground="#FF5722" FontSize="14"/>
                                    </StackPanel>
                                    <Button x:Name="BtnDefrozeBook" Grid.Column="2" Content="Оспорить заморозку" Background="#FF5722" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnDefrozeBook_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
