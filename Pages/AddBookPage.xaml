<Page x:Class="YP.Pages.AddBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddBookPage"
      Background="Aquamarine">
      

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.Column="0" Content="Назад" HorizontalAlignment="Left" Width="80" Cursor="Hand" FontSize="16"

        Margin="0,0,0,0" Click="BtnBack_Click"/>
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Добавление книги" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Width="300" Margin="0,0,10,0"  >
            <TextBlock Text="Путь к картинке:" FontSize="14"/>
            <TextBox x:Name="TxtCoverPath" Height="30" Margin="0,5,0,10" FontSize="12"/>

            <TextBlock Text="Название книги:" FontSize="14"/>
            <TextBox x:Name="TxtTitle" Height="30" Margin="0,5,0,10" FontSize="12"/>

            <TextBlock Text="Выберете подходящие жанры:" FontSize="14"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <ComboBox x:Name="CmbGenre" Width="200" Height="26" DisplayMemberPath="Name" FontSize="12"/>
                <Button Content="Добавить" FontSize="12" Width="95" Height="26" Margin="5,0,0,0" Background="#FFDDDDDD" BorderThickness="1" BorderBrush="#AAAAAA" Click="BtnAddGenre_Click"/>
            </StackPanel>
            <ListBox x:Name="ListBoxGenres" Height="30">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12"/>
                            <Button x:Name="BtnDeleteGenre" Grid.Column="1" Margin="10 0 0 0" Content="Удалить" FontSize="10" Click="BtnDeleteGenre_Click"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="Описание:" Margin="0,10,0,0" FontSize="14"/>
            <TextBox x:Name="TxtDescription" Height="30" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="Текст книги:" FontSize="14"/>
            <TextBox x:Name="TxtContent" Height="200" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <Button Grid.Row="2" Grid.ColumnSpan="2" FontSize="15" Content="Добавить книгу" Width="200" Height="35" Margin="0,10,0,0" Background="#8895af" Foreground="White" Click="BtnAdd_Click"/>
    </Grid>
</Page>

