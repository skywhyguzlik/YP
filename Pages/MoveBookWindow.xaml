<Window x:Class="YP.Pages.MoveBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YP.Pages"
        mc:Ignorable="d"
        Title="MoveBookWindow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="AntiqueWhite">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Переместить книгу" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding Books.Title, StringFormat='Книга: {0}'}" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock Text="Новый статус:" FontSize="14" Margin="0,10,0,5"/>
            <ComboBox x:Name="CmbStatuses" FontSize="12" DisplayMemberPath="Name"/>
            <Button Content="Переместить" Width="120" Height="30" FontSize="14" Margin="0,20,0,0" Background="#8895af" Foreground="White" Click="BtnMove_Click"/>
        </StackPanel>
    </Grid>
</Window>
