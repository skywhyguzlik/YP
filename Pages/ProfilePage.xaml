<Page x:Class="YP.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage"
      Background="AntiqueWhite">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="{Binding Email}" FontSize="14" Foreground="Gray"/>
                <TextBlock Text="{Binding Login}" FontSize="14" Foreground="Gray"/>
                <TextBlock Text="{Binding Roles.RoleName, StringFormat='Роль: {0}'}" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
            <Button x:Name="BtnAuthorRequest" Content="Подать на автора" Visibility="Visible" Background="#8895af" Foreground="White" Width="150" Height="35" Margin="30,0,0,0" VerticalAlignment="Top" Click="BtnAuthorRequest_Click"/>
        </StackPanel>

        <Button x:Name="BtnChangePassword" Grid.Row="1" Content="Сменить пароль" HorizontalAlignment="Left" Width="140" Height="26" FontSize="16" Background="#8895af" Foreground="White" BorderThickness="0" Click="BtnChangePasswordProfile_Click"  Visibility="Collapsed"/>

        <TextBlock Grid.Row="2" Text="Мои отзывы" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox Grid.Row="3" x:Name="ListBoxReviews">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border  Padding="10" Margin="0,0,0,8" BorderBrush="#E0E0E0" BorderThickness="1" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                        <StackPanel>
                            <StackPanel Orientation ="Horizontal">
                                <TextBlock Text="{Binding Books.Title}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text=" — " Foreground="Gray"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" FontSize="12" Foreground="Gray"/>
                                <TextBlock Text="{Binding Rating, StringFormat=' ★{0}'}" FontWeight="Bold" Margin="10,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
