<Page x:Class="YP.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage"
      Background="AntiqueWhite">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">

            <StackPanel VerticalAlignment="Top" Margin="0,10,0,0">
                <Button ToolTip="Каталог книг" Width="70" Height="50" Click="BtnCatalog_Click" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/catalog (1).png"></Image>
                </Button>

                <Button ToolTip="Мои списки" Width="70" Height="50" Click="BtnLists_Click" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/spiski (1).png" ></Image>
                </Button>

                <Button x:Name="BtnAdmin" ToolTip="Администрирование" Width="70" Height="50" Click="BtnAdmin_Click" Visibility="Collapsed" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/param (1).png"></Image>
                </Button>

                <Button x:Name="BtnAuthor" ToolTip="Страница автора" Width="70" Height="50" Click="BtnAuthor_Click" Visibility="Collapsed" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/author (1).png"></Image>
                </Button>

                <Button x:Name="BtnFrozen" ToolTip="Аккаунт заморожен" Width="70" Height="50" Click="BtnFrozen_Click" Visibility="Collapsed" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/signal (2).png"></Image>
                </Button>

                <Button ToolTip="Профиль" Width="70" Height="50" Click="BtnProfile_Click" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/profil (1).png"></Image>
                </Button>
            </StackPanel>
        </Border>

        <Button ToolTip="Выход из профиля" Width="70" Height="50" VerticalAlignment="Bottom" Click="BtnBack_Click" Style="{StaticResource ImageButtonStyle}">
            <Image Source="/Images/back (1).png"></Image>
        </Button>

        <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#E6E9EF"/>
    </Grid>
</Page>
