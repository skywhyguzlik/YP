<Page x:Class="YP.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:YP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage"
      Background="AntiqueWhite">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="5,0">
            <TextBlock Text="Панель администратора" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="{Binding DisplayName}" FontSize="15" Foreground="Gray"/>
        </StackPanel>


        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Жалобы">
                <ListBox x:Name="ListBoxComplaints" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Users.DisplayName, StringFormat='Пользователь: {0}'}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding ComplaintTargetTypes.Name, StringFormat='Жалоба на: {0}'}" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding ComplaintReasons.Name, StringFormat='Причина: {0}'}"/>
                                        <TextBlock Text="{Binding Books.Title, StringFormat='Книга: {0}'}"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='Дата: {0:dd.MM.yyyy HH:mm}'}" Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Content="Принять" Width="90" Height="28" Margin="0,0,0,5" Background="#8895af" Foreground="White" BorderThickness="0" Click="BtnAcceptComplaint_Click"/>
                                        <Button Content="Отклонить" Width="90" Height="28" Background="#E53935" Foreground="White" BorderThickness="0" Click="BtnRejectComplaint_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Заявки на снятие заморозки">
                <ListBox x:Name="ListBoxUnfreeze" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Users.DisplayName, StringFormat='Пользователь: {0}'}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding Reason}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Books.Title, StringFormat='Книга: {0}'}" Foreground="Gray"  Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Content="Принять" Width="90" Height="28" Margin="0,0,0,5" Background="#8895af" Foreground="White" BorderThickness="0" Click="BtnAcceptUnfreeze_Click"/>
                                        <Button Content="Отклонить" Width="90" Height="28" Background="#E53935" Foreground="White" BorderThickness="0" Click="BtnRejectUnfreeze_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Заявки на получение роли автора">
                <ListBox x:Name="ListBoxAuthorApps" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Users.DisplayName, StringFormat='{}{0} хочет стать автором'}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='Дата: {0:dd.MM.yyyy}'}" Foreground="Gray" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Content="Принять" Width="90" Height="28" Margin="0,0,0,5" Background="#8895af" Foreground="White" BorderThickness="0" Click="BtnAcceptAuthorApp_Click"/>
                                        <Button Content="Отклонить" Width="90" Height="28" Background="#E53935" Foreground="White" BorderThickness="0" Click="BtnRejectAuthorApp_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Замороженные">
                <TabControl Margin="5">
                    <TabItem Header="Книги">
                        <ListBox x:Name="ListBoxFrozenBooks" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15"/>
                                                <TextBlock Text="{Binding Users.DisplayName, StringFormat='Автор: {0}'}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Разморозить" Width="110" Height="28" VerticalAlignment="Center" Background="#8895af" Foreground="White" BorderThickness="0" Click="BtnUnfreezeBook_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                    <TabItem Header="Пользователи">
                        <ListBox x:Name="ListBoxFrozenUsers" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="15"/>
                                                <TextBlock Text="{Binding Login}" Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding Roles.RoleName, StringFormat='Роль: {0}'}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Разморозить" Width="110" Height="28" VerticalAlignment="Center" Background="#8895af" Foreground="White" BorderThickness="0" Click="BtnUnfreezeUser_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                    <TabItem Header="Отзывы">
                        <ListBox x:Name="ListBoxFrozenReviews" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Users.DisplayName, StringFormat='Автор: {0}'}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Text}" Margin="0,5,0,0" TextWrapping="Wrap" MaxHeight="60"/>
                                                <TextBlock Text="{Binding Books.Title, StringFormat='Книга: {0}'}" Foreground="Gray" Margin="0,5,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Разморозить" Width="110" Height="28" VerticalAlignment="Center" Background="#8895af" Foreground="White" BorderThickness="0" Click="BtnUnfreezeReview_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="Пользователи">
                <ListBox x:Name="ListBoxAllUsers" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding Login}" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Roles.RoleName, StringFormat='Роль: {0}'}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Изменение роли" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="CmbRole" Width="150" Height="28" Loaded="CmbRole_Loaded" SelectionChanged="CmbRole_SelectionChanged"/>
                                        <Button Content="Сменить пароль" Width="150" Height="28" Margin="0,12,0,0" Click="BtnOpenPasswordWindow_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RoleId}" Value="3">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
